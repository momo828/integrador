  <!-- Bootstrap -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

  <style>
    body {
      background-color: #f5f5f5;
    }
    .card {
      border-radius: 10px;
    }
  </style>
</head>

<body>

<!-- ⭐ MENÚ DE NAVEGACIÓN -->
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
  <div class="container-fluid">
    <a class="navbar-brand" href="index.html">Mi CRUD</a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menu">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="menu">
      <ul class="navbar-nav ms-auto">

        <li class="nav-item">
          <a class="nav-link" href="index.html">Registrar persona</a>
        </li>

        <li class="nav-item">
          <a class="nav-link" href="personas.html">Tarjetas multimedia</a>
        </li>

        <li class="nav-item">
          <a class="nav-link active" href="documentos.html">Solo documentos</a>
        </li>

        <li class="nav-item">
          <a class="nav-link" href="redes.html">Solo redes sociales</a>
        </li>

      </ul>
    </div>
  </div>
</nav>

<!-- ⭐ CONTENEDOR DE DOCUMENTOS -->
<div class="container mt-4">
  <h2 class="text-center mb-4">Documentos PDF</h2>
  <div id="contenedor" class="row g-4"></div>
</div>

<!-- ⭐ SCRIPT PARA CARGAR DOCUMENTOS -->
<script>
async function cargarDocumentos() {
  const res = await fetch("/personas");
  const personas = await res.json();

  const contenedor = document.getElementById("contenedor");
  contenedor.innerHTML = "";

  personas.forEach(p => {
    if (!p.documento_url) return; // Solo mostrar si tiene documento

    contenedor.innerHTML += `
      <div class="col-md-4">
        <div class="card shadow p-3">

          <h5>${p.nombre}</h5>
          <p><strong>Email:</strong> ${p.email}</p>

          <a href="${p.documento_url}" target="_blank" class="btn btn-outline-primary w-100">
            Ver documento PDF
          </a>

        </div>
      </div>
    `;
  });
}

cargarDocumentos();
</script>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>

